APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# RNF-05: enlaces a redes sociales del comercio (opcionales; vacío = no se muestra)
SOCIAL_INSTAGRAM=
SOCIAL_FACEBOOK=
SOCIAL_TIKTOK=

# RNF-24: identidad del comercio (logo y nombre; editable sin tocar código)
COMERCIO_NOMBRE="Balcoa's Café"
COMERCIO_LOGO=/img/logo.png
# Número de mesas del comercio (QR presencial)
COMERCIO_MESAS=50

#--------------------------------------------------------------------------
# RNF-10 — Módulos activables (feature flags)
#--------------------------------------------------------------------------
# Cada flag enciende (true) o apaga (false) un módulo OPCIONAL sin tocar el
# código. Apagado = su ruta responde 404 y su enlace/tarjeta desaparecen del
# panel (corte real en 3 capas). Tras cambiar un flag hay que reiniciar el
# servidor. Los módulos BÁSICOS (menú, pedidos del cliente, panel de pedidos y
# QR de mesa) son el núcleo y NO se pueden apagar (no tienen flag).

# Exportar catálogo y ventas a CSV (RNF-16).
#   true  -> tarjeta "Exportar ventas CSV" + rutas /panel/export/*.csv
#   false -> tarjeta oculta y esas rutas dan 404
MODULE_EXPORT=true

# Métricas de observabilidad en formato Prometheus (endpoint /metrics).
#   true  -> /metrics disponible (para monitoreo con Prometheus/Grafana)
#   false -> /metrics da 404 (dejar así si no usas monitoreo)
MODULE_METRICS=false

# Enlaces a redes sociales en el pie del cliente (RNF-05).
#   true  -> muestra los enlaces definidos en SOCIAL_* (si están vacíos, no muestra nada)
#   false -> nunca muestra el bloque de redes
MODULE_REDES=true

# Reserva de mesas (módulo completo: gestión de reservas en el panel).
#   true  -> aparece el menú "Reservas" y el CRUD en /reservas
#   false -> sin menú y /reservas da 404
MODULE_RESERVAS=false

# Comanda / ticket de cocina imprimible por pedido (RNF-07).
#   true  -> botón "Comanda" en el detalle del pedido (ticket de texto)
#   false -> sin botón y la ruta de la comanda da 404
MODULE_COMANDA=true

# NOTA: el cobro del pedido (RNF-08) NO es un flag: es un paso OBLIGATORIO del
# flujo (el cliente elige método; el efectivo se cobra en persona). No se apaga.
